- Add HONOR_GUEST (主禮嘉賓) and GUEST (嘉賓) to the event-personnel roles,
  wired through server OFF_ROLES, the admin roster editor sections, and the
  bottom-banner role labels in admin + overlay.
- reset.match now closes the display (board tier -> off) and clears the
  roster panels instead of demoting full -> large.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_012TkibpmPnuk9k2YCaWLzT7
---
 public/admin/admin.js     | 5 +++--
 public/overlay/overlay.js | 1 +
 server.js                 | 5 +++--
 3 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/public/admin/admin.js b/public/admin/admin.js
index e2df877..3ef2b6a 100644
--- a/public/admin/admin.js
+++ b/public/admin/admin.js
@@ -390,6 +390,7 @@ $('ibHideBtn').addEventListener('click', () => act('info.hide'));
 const BB_ROLE_LABEL = {
   LEADER: '領隊', COACH: '教練', STAFF: '工作人員', PLAYER: '球員',
   COMMENTATOR: '評論員', REFEREE: '裁判',
+  HONOR_GUEST: '主禮嘉賓', GUEST: '嘉賓',
 };
 const noExt = f => String(f).replace(/\.[^.]+$/, '');
 
@@ -726,7 +727,7 @@ document.querySelectorAll('.swatches').forEach(sw => {
 /* ------------------------------------------------------------ roster */
 
 const ROLE_SECTIONS_TEAM = [['LEADER', '領隊'], ['COACH', '教練'], ['STAFF', '工作人員'], ['PLAYER', '球員']];
-const ROLE_SECTIONS_OFF = [['COMMENTATOR', '評論員'], ['REFEREE', '裁判']];
+const ROLE_SECTIONS_OFF = [['HONOR_GUEST', '主禮嘉賓'], ['GUEST', '嘉賓'], ['COMMENTATOR', '評論員'], ['REFEREE', '裁判']];
 let rosterGroup = 'A';
 let lastRosterJson = '';
 
@@ -1354,7 +1355,7 @@ $('settingsImportFile').addEventListener('change', async e => {
 
 /* danger */
 $('resetMatch').addEventListener('click', () => {
-  if (confirm('重置比分、計時器與橫幅？球隊與顯示設置保留。')) act('reset.match');
+  if (confirm('重置比分、計時器與橫幅，並將顯示關閉？球隊與顯示設置保留。')) act('reset.match');
 });
 $('resetFactory').addEventListener('click', () => {
   if (confirm('恢復出廠設定？所有球隊、顏色、名單與顯示設置都會還原。')) act('reset.factory');
