   COMMENTATOR: '評論員', REFEREE: '裁判',
+  HONOR_GUEST: '主禮嘉賓', GUEST: '嘉賓',
   HOST: '主辦單位', SUPPORT: '支持及指導單位', FUNDER: '資助機構',
 };
